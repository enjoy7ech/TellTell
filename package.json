{
  "name": "telltell-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:editor": "pnpm --filter @telltell/editor run dev",
    "dev:demo": "pnpm --filter @telltell/demo run dev",
    "build": "pnpm -r build",
    "telltell": "pnpm --filter @telltell/cli dev --",
    "meta": "cd packages/core && npx tsx ../cli/src/index.ts meta"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
