{
  "Character": {
    "label": "角色状态",
    "funcs": {
      "addFavor": {
        "label": "增加/修改角色间的数值型好感度",
        "type": "action",
        "params": [
          {
            "name": "fromId",
            "label": "来源角色",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "toId",
            "label": "目标角色",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "amount",
            "label": "变更数量",
            "type": "el-input-number",
            "props": {
              "controls": false
            }
          }
        ]
      },
      "favorGT": {
        "label": "判定角色 A 对角色 B 的好感度是否大于 n",
        "type": "judge",
        "params": [
          {
            "name": "charA",
            "label": "源角色",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "charB",
            "label": "目标角色",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "n",
            "label": "数值",
            "type": "el-input-number",
            "props": {
              "controls": false
            }
          }
        ]
      },
      "favorLT": {
        "label": "判定角色 A 对角色 B 的好感度是否小于 n",
        "type": "judge",
        "params": [
          {
            "name": "charA",
            "label": "源角色",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "charB",
            "label": "目标角色",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "n",
            "label": "数值",
            "type": "el-input-number",
            "props": {
              "controls": false
            }
          }
        ]
      },
      "isInfoUnlocked": {
        "label": "判定指定角色的某条档案信息是否已解锁",
        "type": "judge",
        "params": [
          {
            "name": "charId",
            "label": "角色ID",
            "type": "CharacterSelector",
            "props": {}
          },
          {
            "name": "infoIndex",
            "label": "信息索引",
            "type": "el-input-number",
            "props": {
              "min": "0"
            }
          }
        ]
      }
    }
  },
  "DateTime": {
    "label": "历法系统",
    "funcs": {
      "addMinutes": {
        "label": "增加时间 (分钟)",
        "type": "action",
        "params": [
          {
            "name": "minutes",
            "label": "变更分钟数",
            "type": "el-input-number",
            "props": {}
          }
        ]
      },
      "nextDayAt": {
        "label": "跳转到下一天指定时刻",
        "type": "action",
        "params": [
          {
            "name": "hour",
            "label": "小时",
            "type": "el-input-number",
            "props": {
              "min": "0",
              "max": "23"
            }
          },
          {
            "name": "minute",
            "label": "分钟",
            "type": "el-input-number",
            "props": {
              "min": "0",
              "max": "59"
            }
          }
        ]
      },
      "setAbsoluteTime": {
        "label": "设置绝对时间点 (字符串)",
        "type": "action",
        "params": [
          {
            "name": "dateStr",
            "label": "时间字符串 (YYYY-MM-DD HH:mm)",
            "type": "el-input",
            "props": {}
          }
        ]
      },
      "timeGT": {
        "label": "判定游戏当前时间戳是否大于 T (毫秒)",
        "type": "judge",
        "params": [
          {
            "name": "T",
            "label": "目标时间戳",
            "type": "el-input-number",
            "props": {
              "controls": false
            }
          }
        ]
      },
      "timeLT": {
        "label": "判定游戏当前时间戳是否小于 T (毫秒)",
        "type": "judge",
        "params": [
          {
            "name": "T",
            "label": "目标时间戳",
            "type": "el-input-number",
            "props": {
              "controls": false
            }
          }
        ]
      }
    }
  },
  "Engine": {
    "label": "引擎核心",
    "funcs": {
      "startStoryNode": {
        "label": "启动指定的剧情节点",
        "type": "action",
        "params": [
          {
            "name": "nodeId",
            "label": "节点ID",
            "type": "StoryNodeSelect",
            "props": {}
          }
        ]
      },
      "next": {
        "label": "推进至下一段剧情（集合切页与自动跳转）",
        "type": "action",
        "params": []
      },
      "saveGame": {
        "label": "执行即时存档 (保存当前游戏状态)",
        "type": "action",
        "params": []
      },
      "isNeverStepNode": {
        "label": "永远不会自然进入的节点",
        "type": "judge",
        "params": []
      }
    }
  },
  "Map": {
    "label": "地图系统",
    "funcs": {
      "unlockLocation": {
        "label": "解锁指定地点",
        "type": "action",
        "params": [
          {
            "name": "locId",
            "label": "地点ID",
            "type": "LocationSelector",
            "props": {}
          }
        ]
      },
      "switchMap": {
        "label": "切换当前大地图",
        "type": "action",
        "params": [
          {
            "name": "mapId",
            "label": "地图ID",
            "type": "MapSelector",
            "props": {}
          }
        ]
      },
      "teleport": {
        "label": "传送至指定地点 (需已解锁)",
        "type": "action",
        "params": [
          {
            "name": "locId",
            "label": "地点ID",
            "type": "LocationSelector",
            "props": {}
          }
        ]
      },
      "isLocationUnlocked": {
        "label": "判定指定地点是否已解锁",
        "type": "judge",
        "params": [
          {
            "name": "locId",
            "label": "地点ID",
            "type": "LocationSelector",
            "props": {}
          }
        ]
      },
      "isAtLocation": {
        "label": "判定玩家当前是否在某地点",
        "type": "judge",
        "params": [
          {
            "name": "locId",
            "label": "地点ID",
            "type": "LocationSelector",
            "props": {}
          }
        ]
      }
    }
  }
}
